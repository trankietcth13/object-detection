{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "weights/**",
      "use": "@vercel/static"
    },
    {
      "src": "figures/**",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/weights/(.*)\\.onnx",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
